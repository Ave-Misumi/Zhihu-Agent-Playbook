# ==========================================
# 知乎 Agent Playbook - 环境变量配置示例
# ==========================================
# 使用方法：
#   1. 复制此文件为 .env（去掉 .example 后缀）
#   2. 填入你的真实 API 密钥和配置
#   3. 确保 .env 已添加到 .gitignore，避免泄露密钥

# LLM API 配置（必需）
# 支持：阿里云百炼、SiliconFlow、OpenAI、Ollama 等 OpenAI 兼容服务
LLM_BASE_URL=https://your-api-endpoint.com/v1
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=your-model-name

# 浏览器配置（使用本机 Edge）
# 默认路径如下，通常无需修改
# EDGE_EXECUTABLE_PATH=C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe
# EDGE_USER_DATA_DIR=C:\Users\<你的用户名>\AppData\Local\Microsoft\Edge\User Data
